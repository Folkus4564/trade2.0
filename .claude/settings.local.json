{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch",
      "WebFetch(*)",
      "Skill(claude-api)",
      "Skill(update-config)"
    ]
  },
  "allowEditingSettings": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"CLAUDE.md REMINDER: If new modules, results, architecture, configs, or preferences were added this session, update CLAUDE.md now to reflect the current project state.\"}'",
            "statusMessage": "Checking CLAUDE.md update reminder..."
          }
        ]
      }
    ]
  }
}
