# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Environments
.env
.venv
env/
venv/

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Claude Code (machine-local settings)
.claude/settings.local.json

# Data (raw CSVs and processed intermediates — all levels)
**/data/raw/
**/data/processed/

# Large data file extensions (safety net)
*.parquet
*.csv
*.h5
*.hdf5
*.feather

# Artefacts (generated outputs - not source)
# code3.0/artefacts/ is now tracked (results, approved strategies, models)
artefacts/
!code3.0/artefacts/
!code3.0/artefacts/**

# Models (generated) — allow inside code3.0/artefacts
*.pkl
!code3.0/artefacts/**/*.pkl

# Allow CSVs inside code3.0/artefacts (trade logs, backtest results)
!code3.0/artefacts/**/*.csv

# Backtest and report outputs (legacy locations)
backtests/
backtests_v2/
reports/
reports_v2/
experiments/
approved_strategies/
# Re-allow approved_strategies inside code3.0/artefacts (overrides line above)
!code3.0/artefacts/approved_strategies/
!code3.0/artefacts/approved_strategies/**
!code3.0/artefacts/btcusdt/approved_strategies/
!code3.0/artefacts/btcusdt/approved_strategies/**
